{
  "name": "@statiolake/coc-explorer",
  "version": "0.3.0",
  "description": "A lean filesystem explorer for coc.nvim view containers",
  "author": "statiolake",
  "license": "MIT",
  "main": "lib/index.js",
  "engines": {
    "coc": "^0.0.82"
  },
  "extensionDependencies": [
    "@statiolake/coc-ui"
  ],
  "activationEvents": [
    "*"
  ],
  "scripts": {
    "build": "node esbuild.mjs",
    "prepare": "node esbuild.mjs",
    "typecheck": "tsc --noEmit"
  },
  "contributes": {
    "commands": [
      {
        "command": "explorer.show",
        "title": "Show Explorer"
      },
      {
        "command": "explorer.reveal",
        "title": "Reveal Current File in Explorer"
      },
      {
        "command": "explorer.refresh",
        "title": "Refresh Explorer"
      },
      {
        "command": "explorer.changeRoot",
        "title": "Change Explorer Root"
      },
      {
        "command": "explorer.open",
        "title": "Open Explorer Item"
      },
      {
        "command": "explorer.toggle",
        "title": "Expand or Collapse Explorer Item"
      },
      {
        "command": "explorer.openSplit",
        "title": "Open Explorer Item in Split"
      },
      {
        "command": "explorer.openVsplit",
        "title": "Open Explorer Item in Vertical Split"
      },
      {
        "command": "explorer.openTab",
        "title": "Open Explorer Item in New Tab"
      },
      {
        "command": "explorer.runSystem",
        "title": "Run System Command for Explorer Item"
      },
      {
        "command": "explorer.changeRootTo",
        "title": "Set Explorer Root to Item"
      },
      {
        "command": "explorer.newFile",
        "title": "Create File in Explorer"
      },
      {
        "command": "explorer.newFolder",
        "title": "Create Folder in Explorer"
      },
      {
        "command": "explorer.create",
        "title": "Create Item in Explorer"
      },
      {
        "command": "explorer.rename",
        "title": "Rename Explorer Item"
      },
      {
        "command": "explorer.delete",
        "title": "Delete Explorer Item"
      },
      {
        "command": "explorer.cut",
        "title": "Cut Explorer Item"
      },
      {
        "command": "explorer.copy",
        "title": "Copy Explorer Item"
      },
      {
        "command": "explorer.paste",
        "title": "Paste Explorer Item"
      },
      {
        "command": "explorer.copyPath",
        "title": "Copy Explorer Item Path"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "Coc Explorer",
      "properties": {
        "explorer.root": {
          "type": "string",
          "default": ""
        },
        "explorer.exclude": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            ".git",
            "node_modules",
            ".mypy_cache",
            "__pycache__",
            "target"
          ]
        },
        "explorer.showHidden": {
          "type": "boolean",
          "default": true
        },
        "explorer.icons.folderClosed": {
          "type": "string",
          "default": "",
          "description": "Icon for a collapsed folder"
        },
        "explorer.icons.folderOpen": {
          "type": "string",
          "default": "",
          "description": "Icon for an expanded folder"
        }
      }
    }
  },
  "devDependencies": {
    "@statiolake/coc-ui": "git+https://github.com/statiolake/coc-ui.git",
    "@types/node": "^16.18.0",
    "coc.nvim": "^0.0.83-next.24",
    "esbuild": "^0.25.0",
    "typescript": "^5.3.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/statiolake/explorer.git"
  },
  "bugs": {
    "url": "https://github.com/statiolake/coc-explorer/issues"
  },
  "homepage": "https://github.com/statiolake/coc-explorer#readme",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "lib/index.js"
  ]
}
